generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  phone         String?
  role          String    @default("STUDENT") // STUDENT, ADMIN, TEACHER
  status        String    @default("ACTIVE") // ACTIVE, SUSPENDED
  suspendedUntil DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  devices       Device[]
  enrollments   Enrollment[]
  testResults   Result[]
  doubts        Doubt[]
  doubtReplies  DoubtReply[]
  attendances   Attendance[]
}

model Device {
  id           String   @id @default(cuid())
  userId       String
  deviceId     String   @unique // Hardware/Browser fingerprint
  name         String
  browser      String
  ipAddress    String
  location     String?
  lastLogin    DateTime @default(now())
  status       String   @default("ACTIVE") // ACTIVE, BLOCKED
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Batch {
  id           String   @id @default(cuid())
  title        String
  description  String?
  thumbnail    String?
  price        Float
  startDate    DateTime
  endDate      DateTime
  visibility   String   @default("PUBLIC") // PUBLIC, PRIVATE
  validity     String?
  mode         String?
  schedule     String?
  features     String   @default("[]") // JSON array of feature strings

  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subjects     Subject[]
  enrollments  Enrollment[]
  attendances  Attendance[]
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  batchId   String
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([userId, batchId])
}

model Subject {
  id        String   @id @default(cuid())
  batchId   String
  name      String
  createdAt DateTime @default(now())

  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  chapters  Chapter[]
}

model Chapter {
  id        String   @id @default(cuid())
  subjectId String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  videos    Video[]
  pdfs      PDF[]
  tests     Test[]
}

model Video {
  id          String   @id @default(cuid())
  chapterId   String
  title       String
  description String?
  youtubeId   String?  // For YouTube Links
  videoUrl    String?  // For Direct Video Uploads
  videoType   String   @default("RECORDED") // RECORDED, LIVE
  duration    Int?     // in seconds
  order       Int      @default(0)
  scheduledAt DateTime? // For upcoming/scheduled videos
  isPublished Boolean  @default(true) // false = upcoming/scheduled
  createdAt   DateTime @default(now())

  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  pdfs        PDF[]
}

model PDF {
  id        String   @id @default(cuid())
  chapterId String
  title     String
  type      String   @default("NOTE") // NOTE, DPP
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  videoId   String?
  video     Video?   @relation(fields: [videoId], references: [id], onDelete: Cascade)

  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model Test {
  id        String   @id @default(cuid())
  chapterId String
  title     String
  duration  Int      // in minutes
  marks     Int
  createdAt DateTime @default(now())

  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  questions Question[]
  results   Result[]
}

model Question {
  id        String   @id @default(cuid())
  testId    String
  text      String
  type      String   // MCQ, NUMERICAL, SUBJECTIVE
  options   String?  // JSON string
  answer    String   // Correct option or answer string
  marks     Int      @default(4)
  negative  Int      @default(1)

  test      Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
}

model Result {
  id        String   @id @default(cuid())
  testId    String
  userId    String
  score     Int
  timeTaken Int      // in minutes
  createdAt DateTime @default(now())

  test      Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([testId, userId])
}

model Doubt {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  imageUrl  String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies   DoubtReply[]
}

model DoubtReply {
  id        String   @id @default(cuid())
  doubtId   String
  userId    String
  content   String
  createdAt DateTime @default(now())

  doubt     Doubt    @relation(fields: [doubtId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("Active") // Active, Inactive
  order       Int      @default(0)
  
  // Storing arrays as JSON strings since SQLite doesn't natively support scalar lists
  subjects    String   @default("[]") 
  boards      String   @default("[]")
  exams       String   @default("[]")
  
  ebooks      Ebook[]
  batches     Batch[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Ebook {
  id          String   @id @default(cuid())
  title       String
  chapterName String?
  
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  
  // JSON arrays of selected tags
  subjects    String   @default("[]")
  boards      String   @default("[]")
  exams       String   @default("[]")
  
  description String?
  sourceType  String   @default("URL") // UPLOAD, URL
  fileUrl     String
  pageCount   Int?
  fileSize    String?
  
  status      String   @default("Active") // Active, Inactive
  views       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id        String   @id @default(cuid())
  userId    String
  batchId   String
  date      String   // Format: "YYYY-MM-DD"
  status    String   @default("PRESENT") // PRESENT, ABSENT
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([userId, batchId, date])
}
